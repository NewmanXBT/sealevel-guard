{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealevel-guard.local/schemas/risk-brief.schema.json",
  "title": "Sealevel Guard Risk Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target",
    "framework",
    "complexity_band",
    "requested_action",
    "supported",
    "recommendation",
    "risk_score",
    "ship_blocker",
    "findings"
  ],
  "properties": {
    "target": {
      "type": "string"
    },
    "framework": {
      "type": "string",
      "enum": [
        "anchor",
        "solana-native-uncertain",
        "unsupported"
      ]
    },
    "complexity_band": {
      "type": "string",
      "enum": [
        "tier_1",
        "tier_2",
        "tier_3",
        "unknown"
      ]
    },
    "requested_action": {
      "type": "string",
      "enum": [
        "ship",
        "integrate",
        "allocate"
      ]
    },
    "supported": {
      "type": "boolean"
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "allow",
        "warn",
        "deny",
        "unsupported"
      ]
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "ship_blocker": {
      "type": "boolean"
    },
    "why_this_verdict": {
      "type": [
        "string",
        "null"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "skill",
          "severity",
          "confidence",
          "evidence",
          "trust_consequence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "skill": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "confidence": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "trust_consequence": {
            "type": "string"
          },
          "exploit_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "why_it_matters": {
            "type": [
              "string",
              "null"
            ]
          },
          "contributing_skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
